{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build && node packages/cli/bin/chameleon.js build --config chameleon/chameleon.config.ts && pnpm build:api",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/_chameleon/(.*)",
      "dest": "/api/chameleon"
    },
    {
      "src": "/graphql",
      "dest": "/api/chameleon"
    },
    {
      "src": "/(.*)",
      "dest": "/api/chameleon"
    }
  ]
}
