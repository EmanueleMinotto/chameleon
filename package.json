{
  "name": "chameleon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Open-source mock/faker server — generate realistic API responses from your schemas",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm chameleon serve --config chameleon/chameleon.config.ts --watch",
    "chameleon": "tsx --tsconfig tsconfig.json packages/cli/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,yaml,yml,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
