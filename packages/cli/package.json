{
  "name": "@chameleon/cli",
  "version": "0.1.0",
  "description": "CLI for Chameleon mock server",
  "type": "module",
  "bin": {
    "chameleon": "./bin/chameleon.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@chameleon/core": "workspace:*",
    "@chameleon/server": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "consola": "^3.2.3",
    "esbuild": "^0.23.0",
    "tsx": "^4.19.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
