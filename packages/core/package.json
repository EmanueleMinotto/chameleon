{
  "name": "@chameleon/core",
  "version": "0.1.0",
  "description": "Core logic for Chameleon — schema parsing, annotation resolution, fake data generation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@faker-js/faker": "^9.0.0",
    "deepmerge": "^4.3.1",
    "fast-glob": "^3.3.0",
    "graphql": "^16.9.0",
    "jsonpath-plus": "^10.0.0",
    "micromatch": "^4.0.8",
    "openapi-types": "^12.1.3",
    "postman-collection": "^4.4.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
