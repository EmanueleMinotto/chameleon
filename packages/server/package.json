{
  "name": "@chameleon/server",
  "version": "0.1.0",
  "description": "Hono HTTP server adapter for Chameleon",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@chameleon/core": "workspace:*",
    "graphql": "^16.9.0",
    "graphql-http": "^1.22.0",
    "hono": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
